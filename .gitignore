# Root-level .gitignore for the workspace

# macOS
.DS_Store

# Windows
Thumbs.db

# Node / JavaScript
node_modules/
.pnp/
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js / static outputs
.next/
out/
build/
dist/

# Vercel / Now
.vercel/
.now/

# Production
publish/
wwwroot/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Environment files / secrets
.env
.env.*
.env.local
appsettings.Development.json
appsettings.Local.json
secrets.json

# Logs
logs/
*.log

# Editor directories and IDE files
.vscode/
.idea/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.iml

# .NET build outputs
**/bin/
**/obj/
publish/
artifacts/

# NuGet
*.nupkg
.nuget/packages/

# Databases
*.db
*.sqlite
*.db-journal

# Coverage and testing
coverage/
coverage/**

# Misc
*.pem

# Keep project-specific .gitignore entries below in their directories if needed
